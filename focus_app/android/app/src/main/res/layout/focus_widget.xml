<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0D0D1A">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus Garden"
        android:textColor="#00FF88"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="🔥 0 day streak"
        android:textColor="#E5E7EB"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_today"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ 0m focused today"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/widget_button"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:text="Start Focus"
        android:textColor="#08080F"
        android:backgroundTint="#00FF88"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>

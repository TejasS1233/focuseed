<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#08080F"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOCUSEED"
        android:textColor="#42876F"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/widget_streak_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAY STREAK"
                android:textColor="#6B7280"
                android:textSize="8sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/widget_today_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIN TODAY"
                android:textColor="#6B7280"
                android:textSize="8sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/widget_button"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="8dp"
        android:text="FOCUS"
        android:textColor="#08080F"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:background="#00FF88"
        android:gravity="center"
        android:padding="0dp" />

</LinearLayout>
